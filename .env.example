DJANGO_SECRET_KEY=dev-only-change-me-sprint0-exeq-hub-32b
DJANGO_DEBUG=true
POSTGRES_DB=exeq_hub
POSTGRES_USER=exeq
POSTGRES_PASSWORD=exeq
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_ALWAYS_EAGER=false
# D11 — sync periódico de cobranças abertas (celery beat).
BILLING_SYNC_INTERVAL_SECONDS=300
BILLING_SYNC_BATCH_LIMIT=100
WEBHOOK_GATEWAY_SECRET=replace-with-random-32plus-chars
# Produção: FORCE_SECURE_SECRETS=true e IPs do proxy Inter (ou allowlist CDN).
FORCE_SECURE_SECRETS=false
WEBHOOK_ALLOWED_IPS=
WEBHOOK_TRUST_X_FORWARDED_FOR=false
WEBHOOK_GATEWAY_THROTTLE=60/min
ALLOW_ENV_INTER_CREDENTIALS_FALLBACK=true
PAYMENT_HTTP_MODE=stub
PAYMENT_DEFAULT_PROVIDER=inter
ASAAS_API_TOKEN=
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
# Inter Cobrança v3 — sandbox default; produção: https://cdpj.partners.bancointer.com.br
INTER_API_BASE_URL=https://cdpj-sandbox.partners.uatinter.co
# Auth real Inter = OAuth2 + mTLS (ver Docs/Exeq_Hub_Inter_Billing_Integration_Study.md).
# INTER_API_TOKEN é legado/stub; preferir client_id/secret + cert quando HTTP.
INTER_API_TOKEN=
INTER_CLIENT_ID=
INTER_CLIENT_SECRET=
INTER_CERT_PATH=
INTER_KEY_PATH=
INTER_CERT_PEM=
INTER_KEY_PEM=
INTER_CONTA_CORRENTE=
INTER_OAUTH_TOKEN_PATH=/oauth/v2/token
INTER_OAUTH_SCOPE=boleto-cobranca.read boleto-cobranca.write
INTER_CHARGE_PATH=/cobranca/v3/cobrancas
INTER_CANCEL_PATH_TMPL=/cobranca/v3/cobrancas/{ref}/cancelar
INTER_CANCEL_MOTIVO=ACERTOS
# URL HTTPS pública do Hub (callback Inter Cobrança). Ex.: https://seu-dominio/api/v1/webhooks/gateway
INTER_WEBHOOK_PUBLIC_URL=
INTER_WEBHOOK_PATH=/cobranca/v3/cobrancas/webhook
INTER_WEBHOOK_RETRY_MAX=50
# C6 BaaS — sandbox default; produção: https://baas-api.c6bank.info
C6_API_BASE_URL=https://baas-api-sandbox.c6bank.info
C6_API_TOKEN=
C6_CHARGE_PATH=/v1/bank_slips
C6_CANCEL_PATH_TMPL=/v1/bank_slips/{ref}/cancel
C6_BILLING_SCHEME=21

FOCUS_HTTP_MODE=stub
FOCUS_API_BASE_URL=https://homologacao.focusnfe.com.br
FOCUS_API_TOKEN=
RECEITA_HTTP_MODE=stub
SERPRO_AUTH_URL=https://autenticacao.sapi.serpro.gov.br/authenticate
SERPRO_GATEWAY_URL=https://gateway.apiserpro.serpro.gov.br/integra-contador/v1
SERPRO_ROLE_TYPE=TERCEIROS
SERPRO_EMIT_PATH=Emitir
SERPRO_ID_SISTEMA_DAS=PGDASD
SERPRO_ID_SERVICO_GERAR_DAS=GERARDAS12
SERPRO_ID_SERVICO_GERAR_DARF=
SERPRO_VERSAO_SISTEMA=1.0
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
DAS_REQUIRE_ELECTRONIC_PROXY=false
FIELD_ENCRYPTION_KEY=replace-with-fernet-key
FOCUS_POLL_COUNTDOWN=15
EVOLUTION_HTTP_MODE=stub
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
NFSE_DEFAULT_PROVIDER=focus
NFSE_BETHA_IBGE_CODES=
NFSE_NATIONAL_MANDATORY_FROM=2026-09-01
